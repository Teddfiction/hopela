# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER expose to the client, never commit the real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# Verified sender (or onboarding@resend.dev while testing)
RESEND_FROM="Hopélà! <hello@yourdomain.com>"

# Absolute base URL of the deployed app (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
